<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Etechflow\Faq\Api\FaqRepositoryInterface"
                type="Etechflow\Faq\Model\FaqRepository"/>

    <preference for="Etechflow\Faq\Api\Data\CategoryInterface"
                type="Etechflow\Faq\Model\Category"/>

    <preference for="Etechflow\Faq\Api\Data\ItemInterface"
                type="Etechflow\Faq\Model\Item"/>

    <!-- Contribute FAQ URLs to sitemap.xml -->
    <type name="Magento\Sitemap\Model\ItemProvider\Composite">
        <arguments>
            <argument name="itemProviders" xsi:type="array">
                <item name="etechflow_faq" xsi:type="object">Etechflow\Faq\Model\Sitemap\ItemProvider</item>
            </argument>
        </arguments>
    </type>

    <!--
      License gate on the FAQ repository. Wraps every read method so that
      when the licence is invalid, the repository returns empty results -
      effectively hides ALL FAQ content from REST API consumers, storefront
      blocks, widget rendering, sitemap contribution, and any other caller.
      Storefront controller-level forward to noroute is the cheaper layer;
      this is defense in depth so even API surfaces that bypass controllers
      can't leak data.
    -->
    <type name="Etechflow\Faq\Api\FaqRepositoryInterface">
        <plugin name="etechflow_faq_repository_license_gate"
                type="Etechflow\Faq\Plugin\Api\FaqRepositoryGatePlugin"
                sortOrder="10"/>
    </type>

</config>
