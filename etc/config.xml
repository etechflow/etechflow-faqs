<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <etechflow_faq>
            <license>
                <production_environment>1</production_environment>
                <license_key></license_key>
                <issued_key></issued_key>
                <issued_at>0</issued_at>
                <ip_blocked>0</ip_blocked>
                <portal_url>https://license-service.etechflow.com/license/validate</portal_url>
            </license>
            <branding>
                <primary_color>#C41818</primary_color>
                <secondary_color>#0535F5</secondary_color>
                <text_color>#0E1025</text_color>
                <font_family></font_family>
                <font_family_custom></font_family_custom>
            </branding>
            <seo>
                <enable_schema_jsonld>1</enable_schema_jsonld>
                <enable_breadcrumb_jsonld>1</enable_breadcrumb_jsonld>
                <enable_opengraph>1</enable_opengraph>
                <enable_sitemap>1</enable_sitemap>
            </seo>
            <features>
                <enable_featured_strip>1</enable_featured_strip>
                <enable_visitor_submissions>0</enable_visitor_submissions>
                <enable_tags>1</enable_tags>
                <enable_ajax_search>1</enable_ajax_search>
            </features>
            <hero>
                <enable>1</enable>
                <image_path></image_path>
                <title>Help Centre &amp; FAQs</title>
                <subtitle>Find answers to common questions about orders, shipping, returns, payments and more.</subtitle>
            </hero>
            <contact>
                <show_contact_card>1</show_contact_card>
                <show_need_more_help>1</show_need_more_help>
                <phone></phone>
                <phone_hours></phone_hours>
                <email></email>
                <email_response_time></email_response_time>
                <contact_form_url>contact</contact_form_url>
                <store_finder_url></store_finder_url>
                <phone_icon>phone</phone_icon>
                <email_icon>email</email_icon>
                <contact_form_icon>chat</contact_form_icon>
                <store_finder_icon>map-pin</store_finder_icon>
            </contact>
            <display>
                <related_articles_count>6</related_articles_count>
                <show_helpful_buttons>1</show_helpful_buttons>
                <enable_search_widget>1</enable_search_widget>
                <show_trust_bar>1</show_trust_bar>
            </display>
            <install>
                <install_demo_data>0</install_demo_data>
            </install>
        </etechflow_faq>
    </default>
</config>
