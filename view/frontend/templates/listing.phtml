    <script>
    (function () {
        var f = document.querySelector('[data-kfaq-submit-form]');
        if (!f) return;
        var msg = f.querySelector('[data-kfaq-submit-msg]');
        var btn = f.querySelector('.kfaq-submit-btn');
        var endpoint = <?= json_encode($block->getSubmitEndpoint()) ?>;
        f.addEventListener('submit', function (e) {
            e.preventDefault();
            if (btn.hasAttribute('disabled')) return;
            btn.setAttribute('disabled','disabled');
            msg.textContent = '';
            msg.className = 'kfaq-submit-msg';
            var fd = new FormData(f);
            fetch(endpoint, { method:'POST', body: fd, credentials:'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (j) {
                    if (j && j.ok) {
                        msg.textContent = j.message || 'Thanks!';
                        msg.classList.add('is-ok');
                        f.reset();
                    } else {
                        msg.textContent = (j && j.message) || 'Could not submit. Please try again.';
                        msg.classList.add('is-err');
                    }
                })
                .catch(function () {
                    msg.textContent = 'Network error. Please try again.';
                    msg.classList.add('is-err');
                })
                .finally(function () {
                    btn.removeAttribute('disabled');
                });
        });
    })();
    </script>
