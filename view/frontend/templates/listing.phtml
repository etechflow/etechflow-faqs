// Build a JS-friendly representation of categories for the search filter + modal
$catsForJs = [];
foreach ($cats as $c) {
    $items = method_exists($c, 'getItems') ? ($c->getItems() ?? []) : [];
    $faqs  = [];
    foreach ($items as $it) {
        $faqs[] = [
            'q'    => (string) $it->getQuestion(),
            'a'    => (string) $it->getAnswer(),
            'slug' => (string) ($it->getData('url_key') ?? ''),
        ];
    }
    $catsForJs[] = [
        'id'    => (string) $c->getData('identifier'),
        'label' => (string) $c->getData('label'),
        'faqs'  => $faqs,
    ];
}
$catsJson = json_encode($catsForJs, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT);

/**
 * Render an icon for a category: uploaded image (icon_image) if present,
 * else fall back to the built-in SVG indexed by icon_key.
 */
$renderCatIcon = function ($cat) use ($icons, $cfg, $escaper): string {
    if (!$cat) {
        return $icons['support'];
    }
    $img = (string) $cat->getData('icon_image');
    if ($img !== '') {
        $url = $cfg->resolveMediaUrl($img);
        if ($url !== '') {
            return '<img src="' . $escaper->escapeHtmlAttr($url) . '" alt="" loading="lazy" style="width:100%;height:100%;object-fit:contain;display:block">';
        }
    }
    $key = (string) $cat->getData('icon_key');
    return $icons[$key] ?? $icons['support'];
};

// Build FAQPage JSON-LD covering every active Q&A
$schemaPayload = null;
if ($schemaOn) {
    $mainEntity = [];
    foreach ($cats as $c) {
        $cIdent = (string) $c->getData('identifier');
        $cItems = method_exists($c, 'getItems') ? ($c->getItems() ?? []) : [];
        foreach ($cItems as $it) {
            $slug = (string) ($it->getData('url_key') ?? '');
            $mainEntity[] = [
                '@type'          => 'Question',
                'name'           => (string) $it->getQuestion(),
                'url'            => $slug !== '' ? $block->getDetailUrl($cIdent, $slug) : null,
                'acceptedAnswer' => [
                    '@type' => 'Answer',
                    'text'  => trim(strip_tags((string) $it->getAnswer())),
                ],
            ];
        }
    }
    if (!empty($mainEntity)) {
        $schemaPayload = [
            '@context'   => 'https://schema.org',
            '@type'      => 'FAQPage',
            'mainEntity' => $mainEntity,
        ];
    }
}

