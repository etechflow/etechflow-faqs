<script>
(function () {
    'use strict';
    var root = document.querySelector('[data-kfaq-listing]');
    if (!root) { return; }
    var allCats = <?= /* @noEscape */ $catsJson ?: '[]' ?>;
    var detailUrlPrefix = <?= json_encode(rtrim($block->getDetailUrl('PLACEHOLDER_CAT', 'PLACEHOLDER_SLUG'), 'PLACEHOLDER_SLUG')) ?>;
    // detailUrlPrefix now ends in "PLACEHOLDER_CAT/" — we'll string-replace at runtime

    // ---- Search filter ----
    var searchInputs = root.querySelectorAll('[data-kfaq-search]');
    var noResults    = root.querySelector('[data-kfaq-noresults]');
    var clearBtn     = root.querySelector('[data-kfaq-clear]');

    function applyFilter(term) {
        term = (term || '').trim().toLowerCase();
        var visibleCount = 0;
        // sync the value across desktop + mobile inputs
        searchInputs.forEach(function (i) { if (i.value !== term) { i.value = term; } });
        // each category card (desktop + mobile)
        root.querySelectorAll('[data-cat-id]').forEach(function (card) {
            var catId = card.getAttribute('data-cat-id');
            var cat = allCats.find(function (c) { return c.id === catId; });
            if (!cat) { return; }
            var match = !term || cat.faqs.some(function (f) {
                return f.q.toLowerCase().indexOf(term) >= 0 || (f.a || '').toLowerCase().indexOf(term) >= 0;
            });
            card.classList.toggle('is-hidden', !match);
            if (match) { visibleCount++; }
            // hide individual question rows that don't match (desktop card only)
            card.querySelectorAll('li[data-q-idx]').forEach(function (li) {
                var idx = parseInt(li.getAttribute('data-q-idx'), 10);
                var f = cat.faqs[idx];
                var visible = !term || (f && (f.q.toLowerCase().indexOf(term) >= 0 || (f.a || '').toLowerCase().indexOf(term) >= 0));
                li.classList.toggle('is-hidden', !visible);
            });
        });
        if (noResults) { noResults.classList.toggle('is-on', term !== '' && visibleCount === 0); }
    }

    searchInputs.forEach(function (input) {
        // Stop keystrokes bubbling up to the theme's header search listeners
        input.addEventListener('keydown',  function (e) { e.stopPropagation(); });
        input.addEventListener('keyup',    function (e) { e.stopPropagation(); });
        input.addEventListener('keypress', function (e) { e.stopPropagation(); });
        input.addEventListener('input',    function (e) { e.stopPropagation(); applyFilter(input.value); });
        input.addEventListener('focus',    function (e) { e.stopPropagation(); });
        input.addEventListener('click',    function (e) { e.stopPropagation(); });
    });
    if (clearBtn) {
        clearBtn.addEventListener('click', function () { applyFilter(''); });
    }

    // ---- Modal (all questions per category) ----
    var dialog    = root.querySelector('[data-kfaq-modal]');
    var dlgTitle  = root.querySelector('[data-kfaq-modal-title]');
    var dlgBody   = root.querySelector('[data-kfaq-modal-body]');
    var dlgClose  = root.querySelector('[data-kfaq-modal-close]');
    var supportsDialog = dialog && typeof dialog.showModal === 'function';

    function openModal(catId) {
        var cat = allCats.find(function (c) { return c.id === catId; });
        if (!cat || !dialog) { return; }
        dlgTitle.textContent = cat.label;
        dlgBody.innerHTML = '';
        cat.faqs.forEach(function (f) {
            var a = document.createElement('a');
            a.className = 'kfaq-modal-row';
            a.href = f.slug ? detailUrlPrefix.replace('PLACEHOLDER_CAT/', catId + '/') + f.slug : '#';
            var q = document.createElement('span');
            q.className = 'q';
            q.textContent = f.q;
            var arr = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            arr.setAttribute('class', 'arr');
            arr.setAttribute('width', '15');
            arr.setAttribute('height', '15');
            arr.setAttribute('fill', 'none');
            arr.setAttribute('stroke', 'currentColor');
            arr.setAttribute('stroke-width', '2.5');
            arr.setAttribute('viewBox', '0 0 24 24');
            arr.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>';
            a.appendChild(q);
            a.appendChild(arr);
            dlgBody.appendChild(a);
        });
        if (supportsDialog) {
            dialog.showModal();
        } else {
            // Fallback for browsers without <dialog>: redirect to first question
            if (cat.faqs[0] && cat.faqs[0].slug) {
                window.location.href = detailUrlPrefix.replace('PLACEHOLDER_CAT/', catId + '/') + cat.faqs[0].slug;
            }
        }
    }
    function closeModal() {
        if (dialog && supportsDialog && dialog.open) { dialog.close(); }
    }

    root.querySelectorAll('[data-kfaq-open-modal]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            openModal(btn.getAttribute('data-kfaq-open-modal'));
        });
    });
    if (dlgClose) { dlgClose.addEventListener('click', closeModal); }
    if (dialog) {
        // Click outside the card closes the dialog
        dialog.addEventListener('click', function (e) {
            var rect = dialog.getBoundingClientRect();
            var inDialog = (rect.top <= e.clientY && e.clientY <= rect.top + rect.height &&
                            rect.left <= e.clientX && e.clientX <= rect.left + rect.width);
            if (!inDialog) { closeModal(); }
        });
    }

    // ---- Translate kfaq_q → q on submit so the URL stays /faqs?q=... ----
    root.querySelectorAll('form[data-kfaq-form]').forEach(function (f) {
        f.addEventListener('submit', function (e) {
            var inp = f.querySelector('input[name="kfaq_q"]');
            if (!inp) { return; }
            e.preventDefault();
            var v = (inp.value || '').trim();
            var url = f.getAttribute('action') || window.location.pathname;
            if (v) { url += (url.indexOf('?') >= 0 ? '&' : '?') + 'q=' + encodeURIComponent(v); }
            window.location.href = url;
        });
    });

    // ---- Read ?q=… from URL for deep links ----
    try {
        var params = new URLSearchParams(window.location.search);
        var q = params.get('q');
        if (q) { applyFilter(q); }
    } catch (e) { /* IE / older: silent */ }

    // ---- AJAX search suggestions ----
    var searchUrl = <?= json_encode($searchUrl) ?>;
    var ajaxOn    = <?= $ajaxSearchOn ? 'true' : 'false' ?>;
    if (ajaxOn && searchUrl) {
        var suggestBoxes = root.querySelectorAll('[data-kfaq-suggest]');
        var debounceTimer = null;
        var lastQuery = '';

        function renderSuggest(box, items) {
            if (!items.length) {
                box.innerHTML = '<div class="none">No matches found.</div>';
                box.classList.add('is-on');
                return;
            }
            box.innerHTML = items.map(function (i) {
                return '<a href="' + i.url + '"><span class="q"></span><span class="cat"></span></a>';
            }).join('');
            // Safely set text content (avoid XSS)
            box.querySelectorAll('a').forEach(function (a, idx) {
                a.querySelector('.q').textContent   = items[idx].question || '';
                a.querySelector('.cat').textContent = items[idx].category || '';
            });
            box.classList.add('is-on');
        }
        function hideSuggest(box) {
            box.classList.remove('is-on');
            box.innerHTML = '';
        }

        searchInputs.forEach(function (input) {
            var box = input.closest('.kfaq-msearch-inner, .kfaq-hero-search-input, .kfaq-hero-search, .kfaq-msearch')?.querySelector('[data-kfaq-suggest]');
            if (!box) {
                // Walk parents to find sibling .kfaq-suggest
                var p = input.parentNode;
                while (p && p !== root) { var s = p.querySelector('[data-kfaq-suggest]'); if (s) { box = s; break; } p = p.parentNode; }
            }
            if (!box) { return; }
            input.addEventListener('input', function (e) {
                e.stopPropagation();
                var q = input.value.trim();
                if (debounceTimer) { clearTimeout(debounceTimer); }
                if (q.length < 2) { hideSuggest(box); return; }
                if (q === lastQuery) { return; }
                lastQuery = q;
                debounceTimer = setTimeout(function () {
                    fetch(searchUrl + '?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
                        .then(function (r) { return r.json(); })
                        .then(function (j) { renderSuggest(box, (j && j.results) || []); })
                        .catch(function () { hideSuggest(box); });
                }, 220);
            });
            input.addEventListener('blur', function () {
                // Delay so clicking on a result still fires
                setTimeout(function () { hideSuggest(box); }, 200);
            });
        });
    }
})();
</script>
