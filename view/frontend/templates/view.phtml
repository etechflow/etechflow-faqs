                <script>
                (function () {
                    var f = document.querySelector('[data-kfaq-rail-form]');
                    if (!f) return;
                    var inp  = f.querySelector('[data-kfaq-rail-search]');
                    var box  = document.querySelector('[data-kfaq-rail-suggest]');
                    var endpoint = <?= json_encode($block->getUrl('faqs/search/index')) ?>;
                    var debounceTimer = null;
                    var lastQuery = '';

                    function hideSuggest() {
                        if (!box) return;
                        box.classList.remove('is-on');
                        box.innerHTML = '';
                    }
                    function renderSuggest(items) {
                        if (!box) return;
                        if (!items.length) {
                            box.innerHTML = '<div class="none">No matches found.</div>';
                            box.classList.add('is-on');
                            return;
                        }
                        box.innerHTML = items.map(function () {
                            return '<a href="#"><span class="q"></span><span class="cat"></span></a>';
                        }).join('');
                        box.querySelectorAll('a').forEach(function (a, i) {
                            a.href = items[i].url;
                            a.querySelector('.q').textContent   = items[i].question || '';
                            a.querySelector('.cat').textContent = items[i].category || '';
                        });
                        box.classList.add('is-on');
                    }

                    if (inp) {
                        ['keydown','keyup','keypress','input','focus','click'].forEach(function (ev) {
                            inp.addEventListener(ev, function (e) { e.stopPropagation(); });
                        });
                        inp.addEventListener('input', function () {
                            var q = inp.value.trim();
                            if (debounceTimer) { clearTimeout(debounceTimer); }
                            if (q.length < 2) { hideSuggest(); return; }
                            if (q === lastQuery) { return; }
                            lastQuery = q;
                            debounceTimer = setTimeout(function () {
                                fetch(endpoint + '?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
                                    .then(function (r) { return r.json(); })
                                    .then(function (j) { renderSuggest((j && j.results) || []); })
                                    .catch(function () { hideSuggest(); });
                            }, 220);
                        });
                        inp.addEventListener('blur', function () {
                            setTimeout(hideSuggest, 200);
                        });
                    }

                    // Translate kfaq_q → q on submit
                    f.addEventListener('submit', function (e) {
                        e.preventDefault();
                        var v = inp ? (inp.value || '').trim() : '';
                        var url = f.getAttribute('action') || '/faqs';
                        if (v) { url += (url.indexOf('?') >= 0 ? '&' : '?') + 'q=' + encodeURIComponent(v); }
                        window.location.href = url;
                    });
                })();
                </script>

