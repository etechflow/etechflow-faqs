$listingUrl = $block->getListingUrl();
$catLabel   = $category ? $category->getData('label') : '';
$catIdent   = $category ? $category->getData('identifier') : '';

/**
 * Renders an icon for a category: uploaded image if present, otherwise the
 * built-in SVG by icon_key. Returns ready-to-print HTML (already-escaped).
 */
$renderCatIcon = function ($cat) use ($icons, $cfg, $escaper): string {
    if (!$cat) {
        return $icons['support'];
    }
    $img = (string) $cat->getData('icon_image');
    if ($img !== '') {
        $url = $cfg->resolveMediaUrl($img);
        if ($url !== '') {
            return '<img src="' . $escaper->escapeHtmlAttr($url) . '" alt="" loading="lazy" style="width:100%;height:100%;object-fit:contain;display:block">';
        }
    }
    $key = (string) $cat->getData('icon_key');
    return $icons[$key] ?? $icons['support'];
};

// Build JSON-LD payloads
$ogTitle       = $item->getMetaTitle() !== '' ? $item->getMetaTitle() : $item->getQuestion();
$ogDescription = $item->getMetaDescription() !== ''
    ? $item->getMetaDescription()
    : mb_substr(trim(strip_tags($item->getAnswer())), 0, 200);

$schemaQuestion = null;
if ($schemaOn) {
    $schemaQuestion = [
        '@context'       => 'https://schema.org',
        '@type'          => 'FAQPage',
        'mainEntity'     => [[
            '@type'          => 'Question',
            'name'           => $item->getQuestion(),
            'url'            => $canonical,
            'acceptedAnswer' => [
                '@type' => 'Answer',
                'text'  => trim(strip_tags($item->getAnswer())),
            ],
        ]],
    ];
}

$schemaBreadcrumb = null;
if ($bcOn) {
    $items = [
        ['@type' => 'ListItem', 'position' => 1, 'name' => (string) __('Home'),        'item' => $block->getUrl('')],
        ['@type' => 'ListItem', 'position' => 2, 'name' => (string) __('Help Centre'), 'item' => $listingUrl],
    ];
    if ($catLabel) {
        $items[] = ['@type' => 'ListItem', 'position' => 3, 'name' => $catLabel, 'item' => rtrim($listingUrl, '/') . '#' . $catIdent];
        $items[] = ['@type' => 'ListItem', 'position' => 4, 'name' => $item->getQuestion(), 'item' => $canonical];
    } else {
        $items[] = ['@type' => 'ListItem', 'position' => 3, 'name' => $item->getQuestion(), 'item' => $canonical];
    }
    $schemaBreadcrumb = [
        '@context'        => 'https://schema.org',
        '@type'           => 'BreadcrumbList',
        'itemListElement' => $items,
    ];
}
