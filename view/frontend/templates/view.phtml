<script>
(function () {
    'use strict';
    var root = document.querySelector('.kfaq-view[data-vote-endpoint]');
    if (!root) { return; }
    var helpful = root.querySelector('[data-kfaq-helpful]');
    if (!helpful) { return; }
    var endpoint = root.getAttribute('data-vote-endpoint');
    var itemId   = root.getAttribute('data-item-id');
    var buttons  = helpful.querySelectorAll('.kfaq-helpful-btn');
    var thanks   = helpful.querySelector('.kfaq-helpful-thanks');
    var locked = false;

    function setMsg(text, isErr) {
        if (!thanks) { return; }
        thanks.textContent = text;
        thanks.classList.toggle('is-on', !!text);
        thanks.classList.toggle('is-err', !!isErr);
    }

    buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (locked) { return; }
            locked = true;
            var vote = btn.getAttribute('data-vote');
            buttons.forEach(function (b) {
                b.classList.remove('is-picked-yes', 'is-picked-no');
                b.setAttribute('disabled', 'disabled');
            });
            btn.classList.add(vote === 'yes' ? 'is-picked-yes' : 'is-picked-no');
            var fd = new FormData();
            fd.append('item_id', itemId);
            fd.append('vote', vote);
            fd.append('form_key', (window.FORM_KEY || (window.checkout && window.checkout.formKey) || ''));
            fetch(endpoint, { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (j) {
                    if (j && j.ok) {
                        setMsg(j.message || 'Thanks!', false);
                    } else {
                        setMsg((j && j.message) || 'Could not save your vote.', true);
                        locked = false;
                        buttons.forEach(function (b) { b.removeAttribute('disabled'); });
                    }
                })
                .catch(function () {
                    setMsg('Network error. Please try again.', true);
                    locked = false;
                    buttons.forEach(function (b) { b.removeAttribute('disabled'); });
                });
        });
    });
})();
</script>
