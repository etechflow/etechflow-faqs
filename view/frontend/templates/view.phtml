<?php endif; ?>
<?php if ($schemaBreadcrumb): ?>
<script type="application/ld+json"><?= /* @noEscape */ json_encode($schemaBreadcrumb, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?></script>
<?php endif; ?>

