<meta property="og:type" content="article">
<meta property="og:title" content="<?= $escaper->escapeHtmlAttr($ogTitle) ?>">
<?php if ($ogDescription): ?><meta property="og:description" content="<?= $escaper->escapeHtmlAttr($ogDescription) ?>"><?php endif; ?>
<?php if ($canonical): ?><meta property="og:url" content="<?= $escaper->escapeUrl($canonical) ?>"><?php endif; ?>
<meta name="twitter:card" content="summary">
